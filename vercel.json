{
  "version": 2,
  "builds": [{ "src": "main.py", "use": "@vercel/python" }],
  "functions": {
    "api/index.py": {
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/v1/chat/completions",
      "methods": ["POST"],
      "dest": "main.py"
    },
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ]
}
